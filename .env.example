# Environment variables consumed by AI4comms Deliverables.
#
# Every ${VAR} referenced in .agents/mcp.json must appear here so the
# plugin-completeness validator passes (Inv #4) and downstream clients
# know which secrets they need to set.
#
# Copy to .env (never commit .env) and fill in real values.

# nl-gov-data
NL_GOV_DATA_MCP_URL=
NL_GOV_DATA_MCP_API_KEY=

# stromy-format
STROMY_FORMAT_MCP_URL=
STROMY_FORMAT_MCP_API_KEY=
